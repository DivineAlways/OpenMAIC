      "type": "quiz",
      "title": "Knowledge Check \u2014 Blockchain Basics",
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-eb-1",
            "type": "single",
            "question": "What is the best way to describe a blockchain?",
            "options": [
              {
                "label": "A bank's private database",
                "value": "A"
              },
              {
                "label": "A shared digital notebook that thousands of computers all have a copy of",
                "value": "B"
              },
              {
                "label": "A website run by one company",
                "value": "C"
              },
              {
                "label": "A type of password",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "A blockchain is a shared digital ledger that thousands of computers all hold a copy of. No single person or company controls it \u2014 making it transparent and very hard to cheat.",
            "points": 1
          },
          {
            "id": "q-eb-2",
            "type": "single",
            "question": "What is a 'hash' on a blockchain?",
            "options": [
              {
                "label": "A type of cryptocurrency",
                "value": "A"
              },
              {
                "label": "A special code (fingerprint) that identifies each block",
                "value": "B"
              },
              {
                "label": "The name of a wallet",
                "value": "C"
              },
              {
                "label": "A fee you pay to send money",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "A hash is a unique code \u2014 like a fingerprint \u2014 assigned to each block. If anything in the block changes, the hash changes completely, making tampering obvious to the whole network.",
            "points": 1
          },
          {
            "id": "q-eb-3",
            "type": "single",
            "question": "Why is blockchain hard to cheat?",
            "options": [
              {
                "label": "Because it uses very strong passwords",
                "value": "A"
              },
              {
                "label": "Because a government monitors it",
                "value": "C"
              },
              {
                "label": "Because changing one block breaks the codes of every block after it \u2014 the whole network notices",
                "value": "B"
              },
              {
                "label": "Because only one person can add to it",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Every block contains the fingerprint (hash) of the one before it. Change any block and its fingerprint changes, instantly breaking every block that comes after. The network detects this immediately.",
            "points": 1
          },
          {
            "id": "q-eb-4",
            "type": "single",
            "question": "Which of these is an advantage of blockchain over a traditional bank?",
            "options": [
              {
                "label": "You need a credit score to use it",
                "value": "A"
              },
              {
                "label": "Transactions take 3-5 business days",
                "value": "B"
              },
              {
                "label": "Anyone can use it and transfers happen in seconds with tiny fees",
                "value": "C"
              },
              {
                "label": "A company controls all the rules",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Blockchain lets anyone send money to anyone in the world in seconds with very small fees \u2014 no bank account, no approval, no waiting days. That's the power of decentralized money.",
            "points": 1
          }
        ]
      },
