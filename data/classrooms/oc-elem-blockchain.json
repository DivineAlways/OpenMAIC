              "type": "text",
              "left": 24,
              "top": 66,
              "width": 800,
              "height": 30,
              "rotate": 0,
              "content": "<p style='font-size:13px;color:#64748b;font-weight:500;'>A shared notebook no one can erase \u2014 Elementary Level</p>",
              "defaultFontName": "Inter",
