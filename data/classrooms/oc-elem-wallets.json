              "content": "<p style='font-size:20px;text-align:center;'>🔑</p><p style='font-size:12px;font-weight:800;color:#10b981;text-align:center;'>Public Key</p><p style='font-size:11px;color:#94a3b8;text-align:center;margin-top:4px;'>Like your address — safe to share</p>",
