    {
      "id": "ew-s3",
      "type": "quiz",
      "title": "Knowledge Check — Wallets & Safety",
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-ew-1",
            "type": "single",
            "question": "What does a crypto wallet actually store?",
            "options": [
              {
                "label": "Your cryptocurrency coins",
                "value": "A"
              },
              {
                "label": "Your secret keys that prove ownership of your coins",
                "value": "B"
              },
              {
                "label": "A copy of the entire blockchain",
                "value": "C"
              },
              {
                "label": "Your bank account details",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Your coins live on the blockchain — the wallet stores your private keys, which prove you own those coins. Whoever has the keys, owns the coins.",
            "points": 1
          },
          {
            "id": "q-ew-2",
            "type": "single",
            "question": "What is your public key like?",
            "options": [
              {
                "label": "Your house key — never share it",
                "value": "A"
              },
              {
                "label": "Your home address — safe to share so people can send you crypto",
                "value": "B"
              },
              {
                "label": "Your seed phrase",
                "value": "C"
              },
              {
                "label": "Your bank PIN",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Your public key is like your address. Share it with anyone who wants to send you crypto. It's completely safe to share.",
            "points": 1
          },
          {
            "id": "q-ew-3",
            "type": "single",
            "question": "Which of these is the MOST dangerous thing to do with your seed phrase?",
            "options": [
              {
                "label": "Write it on paper and lock it in a safe",
                "value": "A"
              },
              {
                "label": "Make two copies stored in separate locations",
                "value": "B"
              },
              {
                "label": "Type it into a website that claims to 'verify' your wallet",
                "value": "C"
              },
              {
                "label": "Memorize it",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Typing your seed phrase into ANY website is one of the fastest ways to lose all your crypto. Scammers build fake sites specifically to steal seed phrases.",
            "points": 1
          },
          {
            "id": "q-ew-4",
            "type": "single",
            "question": "What is the difference between a hot wallet and a cold wallet?",
            "options": [
              {
                "label": "Hot wallets are better for large savings, cold wallets for daily spending",
                "value": "A"
              },
