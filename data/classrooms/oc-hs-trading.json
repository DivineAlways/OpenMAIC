              "left": 24,
              "top": 66,
              "width": 800,
              "height": 30,
              "rotate": 0,
              "content": "<p style='font-size:13px;color:#64748b;'>What these tools measure and why the mental game is harder than the technical game</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#64748b"
            },
            {
              "id": "hs-tr-s2-rsi-bg",
              "type": "shape",
              "left": 24,
              "top": 110,
              "width": 450,
              "height": 180,
              "rotate": 0,
              "path": "M 0 0 L 1 0 L 1 1 L 0 1 Z",
