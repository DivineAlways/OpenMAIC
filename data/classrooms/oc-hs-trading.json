              "top": 314,
              "width": 464,
              "height": 26,
              "rotate": 0,
              "content": "<p style='font-size:13px;font-weight:800;color:#f87171;'>🧠 Why Most Traders Lose (Psychology)</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#f87171"
            },
            {
              "id": "hs-tr-s2-psych-b",
              "type": "text",
              "left": 500,
              "top": 342,
              "width": 464,
              "height": 112,
              "rotate": 0,
              "content": "<p style='font-size:12px;color:#94a3b8;line-height:2;'><b style='color:#f87171;'>FOMO</b> — Chasing coins after they're already up 50%<br/><b style='color:#f87171;'>Loss Aversion</b> — Holding losers hoping they come back<br/><b style='color:#f59e0b;'>Overtrading</b> — Forced entries with negative expected value<br/><b style='color:#f59e0b;'>Revenge Trading</b> — Doubling down after a loss to recover</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#94a3b8"
            }
          ]
        }
