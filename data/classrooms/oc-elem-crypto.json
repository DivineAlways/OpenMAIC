      "id": "ec-s3",
      "type": "quiz",
      "title": "Knowledge Check \u2014 Cryptocurrency Basics",
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-ec-1",
            "type": "single",
            "question": "What does 'crypto' in cryptocurrency mean?",
            "options": [
              {
                "label": "It is stored in a physical safe",
                "value": "A"
              },
              {
                "label": "It uses secret codes (cryptography) to stay secure",
                "value": "B"
              },
              {
                "label": "It can only be used online for games",
                "value": "C"
              },
              {
                "label": "It was invented by a government",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "'Crypto' comes from cryptography \u2014 the science of using math-based secret codes. These codes make sure only the real owner of a coin can spend it.",
            "points": 1
          },
          {
            "id": "q-ec-2",
            "type": "single",
            "question": "Which cryptocurrency does OnlyCrypto use for payouts?",
            "options": [
              {
                "label": "Bitcoin",
                "value": "A"
              },
              {
                "label": "Ethereum",
                "value": "B"
              },
              {
                "label": "XRP",
                "value": "C"
              },
              {
                "label": "Dogecoin",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "OnlyCrypto uses XRP (the XRP Ledger) because it settles in 3-5 seconds and has nearly zero fees \u2014 perfect for automatic payouts.",
            "points": 1
          },
          {
            "id": "q-ec-3",
            "type": "single",
            "question": "How many Bitcoin will ever exist in total?",
            "options": [
              {
                "label": "Unlimited",
                "value": "A"
              },
              {
                "label": "1 billion",
                "value": "B"
              },
              {
                "label": "21 million",
                "value": "C"
              },
              {
                "label": "100 thousand",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Bitcoin has a hard cap of 21 million coins \u2014 ever. This scarcity is one reason people treat it like digital gold.",
            "points": 1
          },
          {
            "id": "q-ec-4",
            "type": "single",
            "question": "Which of these is TRUE about cryptocurrency?",
            "options": [
              {
                "label": "A bank must approve every transaction",
                "value": "A"
              },
              {
                "label": "You need a physical wallet to store it",
                "value": "B"
              },
              {
                "label": "You can send it to anyone in the world in seconds",
                "value": "C"
              },
              {
                "label": "Only governments can use it",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Crypto lets you send money to anyone, anywhere, in seconds \u2014 with no bank approval needed. That's what makes it revolutionary.",
            "points": 1
          }
        ]
      }
