              "left": 24,
              "top": 112,
              "width": 460,
              "height": 28,
              "rotate": 0,
              "content": "<p style='font-size:14px;font-weight:800;color:#ef4444;'>📉 Impermanent Loss</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#ef4444"
            },
            {
              "id": "hs-defi-s2-il-b",
              "type": "text",
              "left": 24,
              "top": 142,
              "width": 460,
              "height": 100,
              "rotate": 0,
              "content": "<p style='font-size:12px;color:#94a3b8;line-height:1.8;'>When token prices move, the pool rebalances — your share shifts toward the underperforming token. If you had just held instead of providing liquidity, you'd have more of the outperformer. That difference is impermanent loss.</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#94a3b8"
