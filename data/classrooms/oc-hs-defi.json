            {
              "id": "hs-defi-s2-risks-b",
              "type": "text",
              "left": 524,
              "top": 148,
              "width": 440,
              "height": 250,
              "rotate": 0,
              "content": "<p style='font-size:12px;color:#94a3b8;line-height:2.1;'>⚠️ <b style='color:#f87171;'>Smart contract bugs</b> — $3B+ lost to DeFi hacks in 2022<br/>⚠️ <b style='color:#f87171;'>Rug pulls</b> — Devs drain liquidity pool and disappear<br/>⚠️ <b style='color:#f87171;'>Oracle manipulation</b> — Flash loans manipulate price feeds<br/>⚠️ <b style='color:#f87171;'>Composability risk</b> — One exploit cascades through stacked protocols<br/><br/>✅ <b style='color:#34d399;'>Due diligence:</b> Multiple audits from reputable firms, 6+ months live without incident, growing TVL, open-source code, public team, bug bounty program</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#94a3b8"
            },
            {
              "id": "hs-defi-s2-oc",
              "type": "shape",
