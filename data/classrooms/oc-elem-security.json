    {
      "id": "es-s3",
      "type": "quiz",
      "title": "Knowledge Check — Crypto Security",
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-es-1",
            "type": "single",
            "question": "Someone sends you a DM saying 'I'm from OnlyCrypto support — send me your seed phrase to verify your account.' What should you do?",
            "options": [
              {
                "label": "Send them the seed phrase — it's the support team",
                "value": "A"
              },
              {
                "label": "Block and report them immediately — real support never asks for your seed phrase",
                "value": "B"
              },
              {
                "label": "Send them half the phrase to test if they're real",
                "value": "C"
              },
              {
                "label": "Email them your private key instead",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Real support from any legitimate crypto platform will NEVER ask for your seed phrase or private key. Anyone asking for it is a scammer — block and report immediately.",
            "points": 1
          },
          {
            "id": "q-es-2",
            "type": "single",
            "question": "What is a phishing attack?",
            "options": [
              {
                "label": "A way to mine cryptocurrency using fishing boats",
                "value": "A"
              },
              {
                "label": "A fake website or email designed to look real so you type in your login or seed phrase",
                "value": "B"
              },
              {
                "label": "A type of blockchain consensus mechanism",
                "value": "C"
              },
              {
                "label": "A legal way to earn extra crypto",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Phishing is when scammers create fake websites (or emails) that look identical to real ones. You think you're logging into your real wallet, but you're actually giving your credentials to a thief.",
            "points": 1
          },
          {
            "id": "q-es-3",
            "type": "single",
            "question": "Which of these is the CORRECT way to protect your account?",
            "options": [
              {
                "label": "Use the same password on every site so you don't forget",
                "value": "A"
              },
              {
                "label": "Share your password with a trusted friend as a backup",
                "value": "B"
              },
              {
                "label": "Enable 2FA (two-factor authentication) and use a different strong password for every account",
                "value": "C"
