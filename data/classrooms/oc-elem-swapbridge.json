              "width": 184,
              "height": 70,
              "rotate": 0,
              "content": "<p style='font-size:12px;font-weight:700;color:#8b5cf6;text-align:center;'>\ud83d\udcb1 Swap<br/><span style=\"font-weight:400;color:#94a3b8;\">Exchange one crypto for another</span></p>",
              "defaultFontName": "Inter",
              "defaultColor": "#8b5cf6"
            },
            {
              "id": "esb-s1-box2",
              "type": "shape",
              "left": 238,
