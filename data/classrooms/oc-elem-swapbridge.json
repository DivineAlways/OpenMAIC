    {
      "id": "kc-oc-elem-swapbridge",
      "type": "quiz",
      "title": "Knowledge Check \u2014 Swapping & Bridging",
      "order": 4,
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "kc-oc-elem-swapbridge-q1",
            "type": "single",
            "question": "What is swapping in crypto?",
            "options": [
              {
                "label": "Staking your crypto for yield",
                "value": "A"
              },
              {
                "label": "Exchanging one cryptocurrency for another",
                "value": "B"
              },
              {
                "label": "Moving funds from a hot wallet to a cold wallet",
                "value": "C"
              },
              {
                "label": "Confirming a pending transaction",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Swapping means trading one crypto directly for another \u2014 for example, exchanging ETH for USDC. It can be done on a CEX (like Coinbase) or a DEX (like Uniswap) where a smart contract executes the trade automatically.",
            "points": 1
          },
          {
            "id": "kc-oc-elem-swapbridge-q2",
            "type": "single",
            "question": "What does a bridge do?",
            "options": [
              {
                "label": "Connects a crypto wallet to a bank account",
                "value": "A"
              },
              {
                "label": "Speeds up transactions on a single blockchain",
                "value": "B"
              },
              {
                "label": "Moves tokens between two different blockchains",
                "value": "C"
              },
              {
                "label": "Converts crypto to stablecoins",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Blockchains are separate networks that don't communicate natively. A bridge locks your tokens on Chain A and mints equivalent tokens on Chain B, allowing you to use your assets on a different network.",
            "points": 1
          },
          {
            "id": "kc-oc-elem-swapbridge-q3",
            "type": "single",
            "question": "On a DEX swap, who holds your funds during the trade?",
            "options": [
              {
                "label": "The exchange company",
                "value": "A"
              },
              {
                "label": "A bank escrow",
                "value": "B"
              },
              {
                "label": "No one \u2014 the smart contract executes it and you keep custody",
                "value": "C"
              },
              {
                "label": "The liquidity pool manager",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "DEX swaps are trustless. You connect your own wallet, the smart contract executes the trade, and you receive the new token directly. No company ever holds your funds \u2014 unlike a CEX where the platform has custody.",
            "points": 1
          },
          {
            "id": "kc-oc-elem-swapbridge-q4",
            "type": "single",
            "question": "What is the most common beginner mistake when bridging?",
            "options": [
              {
                "label": "Choosing a DEX instead of a CEX",
                "value": "A"
              },
              {
                "label": "Sending on the wrong network",
                "value": "B"
              },
              {
                "label": "Using a hardware wallet",
                "value": "C"
              },
              {
                "label": "Setting slippage too low",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "The most common expensive mistake: sending ETH on Ethereum mainnet to an address that expects ETH on Arbitrum. The funds appear lost because the receiving wallet isn't watching the right network. Always verify the network on both the sending and receiving side before confirming.",
            "points": 1
          },
          {
            "id": "kc-oc-elem-swapbridge-q5",
            "type": "single",
            "question": "Why are bridges high-value hack targets?",
            "options": [
              {
                "label": "They charge the highest swap fees",
                "value": "A"
              },
              {
                "label": "They are built on outdated technology",
                "value": "B"
              },
              {
                "label": "They lock large amounts of tokens in smart contracts",
                "value": "C"
              },
              {
                "label": "They are not audited",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "Bridges aggregate enormous amounts of locked tokens \u2014 making them attractive targets. The Ronin bridge held $625M when hacked. The Wormhole bridge had $320M stolen. Only use bridges that are audited, battle-tested, and widely used by the community.",
            "points": 1
          }
        ]
      },
      "actions": []
    }
