    {
      "id": "ee-s3",
      "type": "quiz",
      "title": "Knowledge Check \u2014 The Crypto World",
      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-ee-1",
            "type": "single",
            "question": "What does NFT stand for?",
            "options": [
              {
                "label": "New Financial Token",
                "value": "A"
              },
              {
                "label": "Non-Fungible Token",
                "value": "B"
              },
              {
                "label": "Network Finance Technology",
                "value": "C"
              },
              {
                "label": "Not For Trade",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "NFT stands for Non-Fungible Token. 'Non-fungible' means unique or one-of-a-kind \u2014 unlike Bitcoin where every coin is identical and interchangeable.",
            "points": 1
          },
          {
            "id": "q-ee-2",
            "type": "single",
            "question": "What is a DAO?",
            "options": [
              {
                "label": "A type of wallet",
                "value": "A"
              },
              {
                "label": "A government-issued cryptocurrency",
                "value": "B"
              },
              {
                "label": "A group that makes decisions together using blockchain votes \u2014 no CEO needed",
                "value": "C"
              },
              {
                "label": "A trading bot",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "A DAO (Decentralized Autonomous Organization) is a group that votes on decisions using blockchain. Every vote is transparent and the code automatically carries out what the majority decides.",
            "points": 1
          },
          {
            "id": "q-ee-3",
            "type": "single",
            "question": "Which country made Bitcoin legal tender \u2014 meaning you can pay for groceries with it?",
            "options": [
              {
                "label": "USA",
                "value": "A"
              },
              {
                "label": "Japan",
                "value": "B"
              },
              {
                "label": "El Salvador",
                "value": "C"
              },
              {
                "label": "Germany",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "El Salvador became the first country to make Bitcoin legal tender in 2021. Citizens can use Bitcoin to pay for anything \u2014 from groceries to utility bills.",
            "points": 1
          },
          {
            "id": "q-ee-4",
            "type": "single",
            "question": "What makes an NFT different from a regular digital file?",
            "options": [
              {
                "label": "NFTs can only be used in video games",
                "value": "A"
              },
              {
                "label": "NFTs use blockchain to prove ownership \u2014 a regular file can be copied infinitely with no proof of original ownership",
                "value": "B"
              },
              {
                "label": "NFTs are stored on a USB drive",
                "value": "C"
              },
              {
                "label": "NFTs are controlled by the government",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Anyone can save a copy of a JPEG, but an NFT on the blockchain proves who owns the original. It's the difference between a photocopy of the Mona Lisa and owning the actual painting.",
            "points": 1
          }
        ]
      },
