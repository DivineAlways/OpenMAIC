            {
              "id": "et-s1-body",
              "type": "text",
              "left": 24,
              "top": 110,
              "width": 950,
              "height": 130,
              "rotate": 0,
              "content": "<p style='font-size:16px;color:#cbd5e1;line-height:1.8;'>Trading means <b style='color:#60a5fa;'>buying something when the price is low</b> and <b style='color:#f1f5f9;'>selling it when the price is higher</b> \u2014 keeping the difference as profit. Example: You buy 1 XRP for <b style='color:#34d399;'>$2</b>. Later, XRP goes up to <b style='color:#34d399;'>$3</b>. You sell it. You made <b style='color:#fbbf24;'>$1 profit</b> \u2014 that's trading!</p>",
              "defaultFontName": "Inter",
              "defaultColor": "#cbd5e1"
            },
