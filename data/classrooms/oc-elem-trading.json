      "content": {
        "type": "quiz",
        "questions": [
          {
            "id": "q-et-1",
            "type": "single",
            "question": "What is the basic goal of trading?",
            "options": [
              {
                "label": "To hold onto your money forever",
                "value": "A"
              },
              {
                "label": "To buy low and sell high to make a profit",
                "value": "B"
              },
              {
                "label": "To give money to a bank and earn interest",
                "value": "C"
              },
              {
                "label": "To avoid all risk",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "The core of trading is simple: buy when the price is low, sell when the price is higher, and keep the difference as profit.",
            "points": 1
          },
          {
            "id": "q-et-2",
            "type": "single",
            "question": "What is copy trading?",
            "options": [
              {
                "label": "Copying someone else's homework",
                "value": "A"
              },
              {
                "label": "Automatically mirroring an expert trader's buy and sell moves",
                "value": "B"
              },
              {
                "label": "Printing extra copies of a coin",
                "value": "C"
              },
              {
                "label": "Manually watching a trader and copying them by hand",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Copy trading automatically replicates an expert's trades in your account \u2014 when they buy, you buy; when they sell, you sell. No manual effort required.",
            "points": 1
          },
          {
            "id": "q-et-3",
            "type": "single",
            "question": "What is the golden rule of trading?",
            "options": [
              {
                "label": "Always invest everything you have",
                "value": "A"
              },
              {
                "label": "Never invest more than you can afford to lose",
                "value": "B"
              },
              {
                "label": "Only trade during business hours",
                "value": "C"
              },
              {
                "label": "Trust everyone who offers trading tips online",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "Never invest money you can't afford to lose. Even expert traders have bad days. Protecting your capital comes first.",
            "points": 1
          },
          {
            "id": "q-et-4",
            "type": "single",
            "question": "What does OnlyCrypto use for its copy trading?",
            "options": [
              {
                "label": "The New York Stock Exchange",
                "value": "A"
              },
              {
                "label": "A private server",
                "value": "B"
              },
              {
                "label": "The XRP Ledger blockchain",
                "value": "C"
              },
              {
                "label": "A traditional brokerage",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "OnlyCrypto is built on the XRP Ledger \u2014 a fast, low-cost blockchain. Trades settle in 3-5 seconds and payouts go directly to your XRP wallet.",
