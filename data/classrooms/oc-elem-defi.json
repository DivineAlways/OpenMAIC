            "id": "q-ed-1",
            "type": "single",
            "question": "What does DeFi stand for?",
            "options": [
              {
                "label": "Digital Finance",
                "value": "A"
              },
              {
                "label": "Decentralized Finance",
                "value": "B"
              },
              {
                "label": "Distributed Funds",
                "value": "C"
              },
              {
                "label": "Deferred Finance",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "DeFi stands for Decentralized Finance \u2014 financial services that run on blockchains without banks or other middlemen.",
            "points": 1
          },
          {
            "id": "q-ed-2",
            "type": "single",
            "question": "What is a smart contract?",
            "options": [
              {
                "label": "A legal document signed digitally",
                "value": "A"
              },
              {
                "label": "A program on the blockchain that automatically executes when conditions are met",
                "value": "B"
              },
              {
                "label": "A type of cryptocurrency",
                "value": "C"
              },
              {
                "label": "A bank account with smart features",
                "value": "D"
              }
            ],
            "answer": [
              "B"
            ],
            "analysis": "A smart contract is code on the blockchain that runs automatically when certain conditions are met \u2014 like a vending machine that gives you a snack the moment you put in the right amount.",
            "points": 1
          },
          {
            "id": "q-ed-3",
            "type": "single",
            "question": "Which is an advantage of DeFi over a traditional bank?",
            "options": [
              {
                "label": "It requires a credit check",
                "value": "A"
              },
              {
                "label": "It's only open on weekdays",
                "value": "B"
              },
              {
                "label": "Anyone can access it 24/7 with no approval needed",
                "value": "C"
              },
              {
                "label": "The government guarantees your money",
                "value": "D"
              }
            ],
            "answer": [
              "C"
            ],
            "analysis": "DeFi is open to everyone, 24 hours a day, 7 days a week. You don't need a bank account, a credit score, or anyone's approval.",
            "points": 1
          },
